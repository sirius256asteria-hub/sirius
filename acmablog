<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width" />
  <title>α Canis Majoris</title>
  <style>
*, *::before, *::after {
  box-sizing: border-box;
}

/* ベース設定 */
body {
  background-color: #151820;
  color: #d1d5db;
  font-family: sans-serif;
}


/* Header: 深宇宙のグラデーション背景 */
header {
  background: linear-gradient(135deg, #050810 0%, #171b2d 50%, #201533 100%);
  padding: 30px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
}


.container {
    width: 100%;
    min-height: 100vh;
    display: flex;
  }

/* Section: 宇宙の奥行きを表現するコンテンツエリア */
.section {
  width: 80%;
  background-color: #0c1122;
  border: 1px solid rgba(72, 202, 228, 0.1);
  border-radius: 8px;
  padding: 25px;
  margin: 20px 0;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
}

.side {
  width: 20%;
  background-color: #0c1122;
  border: 1px solid rgba(72, 202, 228, 0.1);
  border-radius: 8px;
  padding: 25px;
  margin: 20px 0;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
}


/* Footer: 深宇宙の最深部をイメージした最下部 */
footer {
  background: linear-gradient(to top, #020408 0%, #0b0f19 100%);
  color: #718096; /* 控えめな星屑を意識したグレー */
  text-align: center;
  padding: 40px 20px;
  margin-top: 50px;
  border-top: 1px solid rgba(157, 78, 221, 0.2); /* 微かな星雲の光の境界線 */
  font-size: 0.9rem;
}

footer a {
  color: #48cae4;
  text-decoration: none;
  transition: color 0.3s ease;
}

footer a:hover {
  color: #9d4edd;
  text-shadow: 0 0 8px #9d4edd;
}

/* H1: 星雲のグラデーションテキストと微かな発光 */
h1 {
  font-size: 2.5rem;
  background: linear-gradient(to right, #48cae4, #9d4edd, #ff9e00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0px 0px 15px rgba(157, 78, 221, 0.3);
  margin-bottom: 1rem;
}

/* H2: 彗星の尾や軌道を模した装飾 */
h2 {
  font-size: 1.8rem;
  color: #e2e8f0;
  position: relative;
  padding-bottom: 10px;
  margin-top: 2rem;
}

h2::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 2px;
  background: linear-gradient(to right, #48cae4, transparent);
  box-shadow: 0 0 8px #48cae4;
}

/* H3: 星の瞬きを意識したアクセント */
h3 {
  font-size: 1.4rem;
  color: #a0c4ff;
  border-left: 3px solid #9d4edd;
  padding-left: 12px;
  box-shadow: -2px 0 5px -2px #9d4edd;
}

/* style.css の末尾に追記 */
@media screen and (max-width: 768px) {
  .container {
    flex-direction: column; /* 縦並びに変更 */
  }
  .side, .section {
    width: 100%; /* スマホでは幅を100%にする */
    margin: 10px 0;
  }
}
  </style>

</head>
<body>
  <header>
        <h1>ブログ</h1>
  </header>
  <div class="container">
    <div class="side">
    <h3>内容</h3>
      <ul>
        <li><a href="https://sirius.sirius256asteria.workers.dev">ホーム</a></li>
        <li><a href="https://sirius.sirius256asteria.workers.dev/acmablog">ブログ</a></li>
      </ul>
    </div>
    <div class="section">
    <h2>2026年</h2>
    <h3>12月</h3>
    <h3>11月</h3>
    <h3>10月</h3>
    <h3>9月</h3>
    <h3>8月</h3>
    <h3>7月</h3>
      <ul>
        <li>#1 HPを作成しました (2026/07/06)<br>Keywords: その他, 開発</li>
      </ul>
    </div>
  </div>
  <footer>
    <div>
      <p>&copy; 2026 α Canis Majoris. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
